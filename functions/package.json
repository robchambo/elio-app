{
  "name": "functions",
  "description": "Cloud Functions for Elio — Crashlytics → Notion pipe (Tier 2).",
  "private": true,
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test:copy-fixtures": "node -e \"const{cpSync,existsSync,mkdirSync}=require('node:fs');const{join}=require('node:path');const src=join('src','orderImport','__tests__','fixtures');const dst=join('lib','orderImport','__tests__','fixtures');if(existsSync(src)){mkdirSync(dst,{recursive:true});cpSync(src,dst,{recursive:true});}\"",
    "test": "tsc && npm run test:copy-fixtures && node --test lib/**/__tests__/*.test.js"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@notionhq/client": "^2.2.15",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-google": "^0.14.0",
    "firebase-functions-test": "^3.4.0",
    "typescript": "^5.5.4"
  }
}
